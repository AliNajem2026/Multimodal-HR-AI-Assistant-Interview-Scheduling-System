# Core API Settings
ANTHROPIC_API_KEY="Your actual Anthropic API key here"
FASTAPI_ENV="production"
PORT=8000


# Set to true to skip Google Calendar and run with demo data
USE_MOCK_CALENDAR=true

# Google OAuth Credentials Configuration Paths
# Set USE_MOCK_CALENDAR=false and provide credentials.json to use real Google Calendar.
# Download your OAuth 2.0 Client ID JSON from: Google Cloud Console → APIs & Services → Credentials
GOOGLE_APPLICATION_CREDENTIALS=credentials.json